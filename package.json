{
  "name": "sql-bridge-app",
  "version": "1.0.0",
  "description": "Desktop app to bridge local SQL Server data to any destination (webhooks, Google Sheets, APIs)",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && electron .",
    "dev": "tsc && electron .",
    "watch": "tsc --watch",
    "package": "electron-builder"
  },
  "keywords": [
    "sql",
    "bridge",
    "automation",
    "electron"
  ],
  "author": "krishna",
  "license": "MIT",
  "devDependencies": {
    "@types/mssql": "^9.1.8",
    "@types/node": "^20.19.21",
    "@types/node-cron": "^3.0.11",
    "electron": "^38.2.2",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@electron/remote": "^2.1.3",
    "axios": "^1.6.2",
    "googleapis": "^129.0.0",
    "mssql": "^12.0.0",
    "node-cron": "^3.0.3",
    "xlsx": "^0.18.5"
  },
  "build": {
    "appId": "com.sqlbridge.app",
    "productName": "SQL Bridge",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "config/**/*",
      "src/renderer/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    }
  }
}
