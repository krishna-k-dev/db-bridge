const { ipcRenderer } = require("electron");

// Tab switching
document.querySelectorAll(".tab-btn").forEach((btn) => {
  btn.addEventListener("click", () => {
    const tabName = btn.dataset.tab;

    // Update active tab button
    document
      .querySelectorAll(".tab-btn")
      .forEach((b) => b.classList.remove("active"));
    btn.classList.add("active");

    // Update active tab content
    document
      .querySelectorAll(".tab-content")
      .forEach((t) => t.classList.remove("active"));
    document.getElementById(`${tabName}-tab`).classList.add("active");

    // Load data for the active tab
    if (tabName === "jobs") {
      loadJobs();
    } else if (tabName === "logs") {
      loadLogs();
    }
  });
});

// Load jobs
async function loadJobs() {
  const jobsList = document.getElementById("jobs-list");
  jobsList.innerHTML = '<div class="spinner"></div>';

  try {
    const jobs = await ipcRenderer.invoke("get-jobs");

    if (jobs.length === 0) {
      jobsList.innerHTML = `
        <div class="empty-state">
          <h3>📭 No jobs configured</h3>
          <p>Click "Add Job" to create your first sync job</p>
        </div>
      `;
      return;
    }

    jobsList.innerHTML = jobs
      .map(
        (job) => `
      <div class="job-card ${job.enabled ? "" : "disabled"}">
        <div class="job-header">
          <div>
            <div class="job-title">${job.name}</div>
            <div style="color: #718096; margin-top: 5px;">#${job.id}</div>
          </div>
          <span class="job-status ${job.enabled ? "enabled" : "disabled"}">
            ${job.enabled ? "✓ Enabled" : "✗ Disabled"}
          </span>
        </div>
        
        <div class="job-details">
          <div class="job-detail-item">
            <strong>Database</strong>
            ${job.connection.server} / ${job.connection.database}
          </div>
          <div class="job-detail-item">
            <strong>Schedule</strong>
            ${job.schedule}
          </div>
          <div class="job-detail-item">
            <strong>Trigger</strong>
            ${job.trigger}
          </div>
          <div class="job-detail-item">
            <strong>Destinations</strong>
            ${job.destinations.map((d) => d.type).join(", ")}
          </div>
          <div class="job-detail-item">
            <strong>Last Run</strong>
            ${job.lastRun ? new Date(job.lastRun).toLocaleString() : "Never"}
          </div>
        </div>

        <div class="job-actions">
          <button class="btn btn-primary btn-sm" onclick="runJob('${
            job.id
          }')">▶️ Run Now</button>
          <button class="btn btn-primary btn-sm" onclick="testJob('${
            job.id
          }')">🔌 Test Query</button>
          <button class="btn btn-${
            job.enabled ? "secondary" : "success"
          } btn-sm" onclick="toggleJob('${job.id}', ${!job.enabled})">
            ${job.enabled ? "⏸️ Disable" : "▶️ Enable"}
          </button>
          <button class="btn btn-danger btn-sm" onclick="deleteJob('${
            job.id
          }')">🗑️ Delete</button>
        </div>
      </div>
    `
      )
      .join("");
  } catch (error) {
    jobsList.innerHTML = `<div class="empty-state"><h3>❌ Error loading jobs</h3><p>${error.message}</p></div>`;
  }
}

// Load logs
async function loadLogs() {
  const logsContainer = document.getElementById("logs-container");
  logsContainer.innerHTML = '<div class="spinner"></div>';

  try {
    const logs = await ipcRenderer.invoke("get-logs");

    if (logs.length === 0) {
      logsContainer.innerHTML =
        '<div style="text-align: center; opacity: 0.6;">No logs yet</div>';
      return;
    }

    logsContainer.innerHTML = logs
      .map((log) => {
        let className = "info";
        if (log.includes("[ERROR]")) className = "error";
        else if (log.includes("[WARN]")) className = "warn";

        return `<div class="log-line ${className}">${escapeHtml(log)}</div>`;
      })
      .join("");

    // Scroll to bottom
    logsContainer.scrollTop = logsContainer.scrollHeight;
  } catch (error) {
    logsContainer.innerHTML = `<div class="log-line error">Error loading logs: ${error.message}</div>`;
  }
}

// Job actions
async function runJob(jobId) {
  if (!confirm("Run this job now?")) return;

  try {
    const result = await ipcRenderer.invoke("run-job", jobId);
    if (result.success) {
      alert("✅ Job executed successfully!");
      loadJobs();
    } else {
      alert(`❌ Job failed: ${result.message}`);
    }
  } catch (error) {
    alert(`❌ Error: ${error.message}`);
  }
}

async function testJob(jobId) {
  try {
    const result = await ipcRenderer.invoke("test-job", jobId);
    if (result.success) {
      alert(`✅ ${result.message}\n\nRows returned: ${result.rowCount}`);
    } else {
      alert(`❌ ${result.message}`);
    }
  } catch (error) {
    alert(`❌ Error: ${error.message}`);
  }
}

async function toggleJob(jobId, enabled) {
  try {
    await ipcRenderer.invoke("update-job", jobId, { enabled });
    loadJobs();
  } catch (error) {
    alert(`❌ Error: ${error.message}`);
  }
}

async function deleteJob(jobId) {
  if (!confirm("Delete this job permanently?")) return;

  try {
    await ipcRenderer.invoke("delete-job", jobId);
    alert("✅ Job deleted successfully!");
    loadJobs();
  } catch (error) {
    alert(`❌ Error: ${error.message}`);
  }
}

// Refresh buttons
document.getElementById("refresh-btn").addEventListener("click", loadJobs);
document.getElementById("refresh-logs-btn").addEventListener("click", loadLogs);
document
  .getElementById("clear-logs-btn")
  .addEventListener("click", async () => {
    if (!confirm("Clear all logs?")) return;
    await ipcRenderer.invoke("clear-logs");
    loadLogs();
  });

// Add job form
document.getElementById("job-form").addEventListener("submit", async (e) => {
  e.preventDefault();

  const job = {
    id: document.getElementById("job-id").value,
    name: document.getElementById("job-name").value,
    enabled: true,
    connection: {
      server: document.getElementById("db-server").value,
      database: document.getElementById("db-database").value,
      user: document.getElementById("db-user").value || undefined,
      password: document.getElementById("db-password").value || undefined,
      options: {
        trustServerCertificate:
          document.getElementById("db-trust-cert").checked,
      },
    },
    query: document.getElementById("job-query").value,
    schedule: document.getElementById("job-schedule").value,
    trigger: document.getElementById("job-trigger").value,
    destinations: getDestinations(),
  };

  try {
    await ipcRenderer.invoke("add-job", job);
    alert("✅ Job created successfully!");
    document.getElementById("job-form").reset();
    document.querySelector('[data-tab="jobs"]').click();
  } catch (error) {
    alert(`❌ Error: ${error.message}`);
  }
});

// Test connection
document
  .getElementById("test-connection-btn")
  .addEventListener("click", async () => {
    const tempJob = {
      id: "test",
      name: "Test",
      enabled: false,
      connection: {
        server: document.getElementById("db-server").value,
        database: document.getElementById("db-database").value,
        user: document.getElementById("db-user").value || undefined,
        password: document.getElementById("db-password").value || undefined,
        options: {
          trustServerCertificate:
            document.getElementById("db-trust-cert").checked,
        },
      },
      query: document.getElementById("job-query").value || "SELECT 1",
      schedule: "* * * * *",
      trigger: "always",
      destinations: [],
    };

    try {
      await ipcRenderer.invoke("add-job", tempJob);
      const result = await ipcRenderer.invoke("test-job", "test");
      await ipcRenderer.invoke("delete-job", "test");

      if (result.success) {
        alert(`✅ Connection successful!\n\n${result.message}`);
      } else {
        alert(`❌ Connection failed:\n\n${result.message}`);
      }
    } catch (error) {
      alert(`❌ Error: ${error.message}`);
    }
  });

// Destination management
let destCounter = 1;

document.getElementById("add-destination-btn").addEventListener("click", () => {
  const container = document.getElementById("destinations-container");
  const destItem = document.createElement("div");
  destItem.className = "destination-item";
  destItem.innerHTML = `
    <select class="dest-type">
      <option value="">-- Select Type --</option>
      <option value="webhook">Webhook</option>
      <option value="google_sheets">Google Sheets</option>
      <option value="custom_api">Custom API</option>
    </select>
    <div class="dest-config"></div>
    <button type="button" class="btn btn-danger btn-sm remove-dest">Remove</button>
  `;
  container.appendChild(destItem);

  destItem.querySelector(".dest-type").addEventListener("change", (e) => {
    updateDestinationConfig(destItem, e.target.value);
  });

  destItem.querySelector(".remove-dest").addEventListener("click", () => {
    destItem.remove();
  });

  destCounter++;
});

// Handle dest type change for first item
document.querySelector(".dest-type").addEventListener("change", (e) => {
  updateDestinationConfig(
    e.target.closest(".destination-item"),
    e.target.value
  );
});

document.querySelector(".remove-dest").addEventListener("click", (e) => {
  e.target.closest(".destination-item").remove();
});

function updateDestinationConfig(destItem, type) {
  const configDiv = destItem.querySelector(".dest-config");

  if (type === "webhook") {
    configDiv.innerHTML = `
      <div class="form-group">
        <label>URL *</label>
        <input type="url" class="dest-url" required>
      </div>
      <div class="form-group">
        <label>Method</label>
        <select class="dest-method">
          <option value="POST">POST</option>
          <option value="PUT">PUT</option>
          <option value="PATCH">PATCH</option>
        </select>
      </div>
      <div class="form-group">
        <label>Headers (JSON)</label>
        <textarea class="dest-headers" rows="2" placeholder='{"Authorization": "Bearer token"}'></textarea>
      </div>
    `;
  } else if (type === "google_sheets") {
    configDiv.innerHTML = `
      <div class="form-group">
        <label>Spreadsheet ID *</label>
        <input type="text" class="dest-spreadsheet-id" required>
        <small>Found in the URL: docs.google.com/spreadsheets/d/<strong>SPREADSHEET_ID</strong>/edit</small>
      </div>
      <div class="form-group">
        <label>Sheet Name *</label>
        <input type="text" class="dest-sheet-name" required placeholder="Sheet1">
      </div>
      <div class="form-group">
        <label>Mode *</label>
        <select class="dest-mode">
          <option value="append">Append (add new rows)</option>
          <option value="replace">Replace (clear & write)</option>
          <option value="update">Update (by key column)</option>
        </select>
      </div>
      <div class="form-group">
        <label>Key Column (for update mode)</label>
        <input type="text" class="dest-key-column" placeholder="id">
      </div>
      <div class="form-group">
        <label>Credentials Path *</label>
        <input type="text" class="dest-credentials-path" required value="./config/google-credentials.json">
      </div>
    `;
  } else if (type === "custom_api") {
    configDiv.innerHTML = `
      <div class="form-group">
        <label>API URL *</label>
        <input type="url" class="dest-url" required>
      </div>
      <div class="form-group">
        <label>Method</label>
        <select class="dest-method">
          <option value="POST">POST</option>
          <option value="PUT">PUT</option>
          <option value="PATCH">PATCH</option>
        </select>
      </div>
      <div class="form-group">
        <label>Headers (JSON)</label>
        <textarea class="dest-headers" rows="2" placeholder='{"Authorization": "Bearer token"}'></textarea>
      </div>
    `;
  } else {
    configDiv.innerHTML = "";
  }
}

function getDestinations() {
  const destinations = [];
  document.querySelectorAll(".destination-item").forEach((item) => {
    const type = item.querySelector(".dest-type").value;
    if (!type) return;

    const dest = { type };

    if (type === "webhook") {
      dest.url = item.querySelector(".dest-url").value;
      dest.method = item.querySelector(".dest-method").value;
      const headersText = item.querySelector(".dest-headers").value;
      if (headersText) {
        try {
          dest.headers = JSON.parse(headersText);
        } catch (e) {
          alert("Invalid JSON in webhook headers");
        }
      }
    } else if (type === "google_sheets") {
      dest.spreadsheetId = item.querySelector(".dest-spreadsheet-id").value;
      dest.sheetName = item.querySelector(".dest-sheet-name").value;
      dest.mode = item.querySelector(".dest-mode").value;
      dest.keyColumn =
        item.querySelector(".dest-key-column").value || undefined;
      dest.credentialsPath = item.querySelector(".dest-credentials-path").value;
    } else if (type === "custom_api") {
      dest.url = item.querySelector(".dest-url").value;
      dest.method = item.querySelector(".dest-method").value;
      const headersText = item.querySelector(".dest-headers").value;
      if (headersText) {
        try {
          dest.headers = JSON.parse(headersText);
        } catch (e) {
          alert("Invalid JSON in custom API headers");
        }
      }
    }

    destinations.push(dest);
  });

  return destinations;
}

// Helper function
function escapeHtml(text) {
  const div = document.createElement("div");
  div.textContent = text;
  return div.innerHTML;
}

// Initial load
loadJobs();
