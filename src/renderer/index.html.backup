<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SQL Bridge - Data Sync App</title>
    <link rel="stylesheet" href="style.css" />
  </head>
  <body>
    <div class="container">
      <header>
        <h1>🔄 SQL Bridge</h1>
        <p>Sync your local SQL Server data anywhere</p>
      </header>

      <div class="tabs">
        <button class="tab-btn active" data-tab="jobs">Jobs</button>
        <button class="tab-btn" data-tab="logs">Logs</button>
        <button class="tab-btn" data-tab="add-job">Add Job</button>
      </div>

      <!-- Jobs Tab -->
      <div class="tab-content active" id="jobs-tab">
        <div class="toolbar">
          <button id="refresh-btn" class="btn btn-primary">🔄 Refresh</button>
        </div>
        <div id="jobs-list"></div>
      </div>

      <!-- Logs Tab -->
      <div class="tab-content" id="logs-tab">
        <div class="toolbar">
          <button id="refresh-logs-btn" class="btn btn-primary">
            🔄 Refresh Logs
          </button>
          <button id="clear-logs-btn" class="btn btn-danger">
            🗑️ Clear Logs
          </button>
        </div>
        <div id="logs-container"></div>
      </div>

      <!-- Add Job Tab -->
      <div class="tab-content" id="add-job-tab">
        <div class="form-container">
          <h2>Add New Job</h2>
          <form id="job-form">
            <div class="form-group">
              <label>Job Name *</label>
              <input type="text" id="job-name" required />
            </div>

            <div class="form-group">
              <label>Job ID *</label>
              <input
                type="text"
                id="job-id"
                required
                placeholder="e.g., job1, sales-sync"
              />
            </div>

            <h3>Database Connection</h3>
            <div class="form-row">
              <div class="form-group">
                <label>Server *</label>
                <input
                  type="text"
                  id="db-server"
                  required
                  placeholder="localhost"
                />
              </div>
              <div class="form-group">
                <label>Database *</label>
                <input
                  type="text"
                  id="db-database"
                  required
                  placeholder="MyDatabase"
                />
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label>Username</label>
                <input type="text" id="db-user" placeholder="sa" />
              </div>
              <div class="form-group">
                <label>Password</label>
                <input type="password" id="db-password" />
              </div>
            </div>

            <div class="form-group">
              <label>
                <input type="checkbox" id="db-trust-cert" checked />
                Trust Server Certificate
              </label>
            </div>

            <h3>Query</h3>
            <div class="form-group">
              <label>SQL Query *</label>
              <textarea
                id="job-query"
                rows="5"
                required
                placeholder="SELECT * FROM TableName"
              ></textarea>
            </div>

            <h3>Schedule & Trigger</h3>
            <div class="form-row">
              <div class="form-group">
                <label>Schedule *</label>
                <input
                  type="text"
                  id="job-schedule"
                  required
                  placeholder="*/2 * * * * (every 2 min)"
                />
                <small>Cron expression or simple format: 2m, 5m, etc.</small>
              </div>
              <div class="form-group">
                <label>Trigger</label>
                <select id="job-trigger">
                  <option value="always">Always</option>
                  <option value="onChange">On Change</option>
                </select>
              </div>
            </div>

            <h3>Destinations</h3>
            <div id="destinations-container">
              <div class="destination-item">
                <select class="dest-type">
                  <option value="">-- Select Type --</option>
                  <option value="webhook">Webhook</option>
                  <option value="google_sheets">Google Sheets</option>
                  <option value="custom_api">Custom API</option>
                </select>
                <div class="dest-config"></div>
                <button type="button" class="btn btn-danger btn-sm remove-dest">
                  Remove
                </button>
              </div>
            </div>
            <button
              type="button"
              id="add-destination-btn"
              class="btn btn-secondary"
            >
              + Add Destination
            </button>

            <div class="form-actions">
              <button type="submit" class="btn btn-success">💾 Save Job</button>
              <button
                type="button"
                id="test-connection-btn"
                class="btn btn-primary"
              >
                🔌 Test Connection
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <script src="app.js"></script>
  </body>
</html>
